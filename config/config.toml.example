# -----------------------------------------------------------------------------
# Message-Service -- PRODUCTION config template
# -----------------------------------------------------------------------------
# Copy this file to `config.toml` at the repo root (or wherever you deploy
# the service), fill in the real values, and launch with:
#
#   poetry run python -m message_service --config config.toml
#
# or via the env-var fallback:
#
#   MESSAGE_SERVICE_CONFIG=/etc/message-service/config.toml \
#       poetry run python -m message_service
#
# SECRETS POLICY
# --------------
# Fields of type `SubstitutableStr` (documented per-field below) support
# the syntax `${env:VAR_NAME}` for environment-variable substitution.
# Currently only [mail.smtp].username and [mail.smtp].password are
# substitutable. Anything else is taken literally.
#
# DO NOT COMMIT THIS FILE WITH REAL SECRETS. Your `.gitignore` should
# include `/config.toml` at the repo root (but NOT `config/`).
#
# -----------------------------------------------------------------------------

# --- Listeners ---------------------------------------------------------------

[grpc]
# Bind 0.0.0.0 behind a reverse proxy / firewall; bind the internal
# interface if your deployment has one. Plaintext per L1-API-003;
# transport security is handled by the network layer.
host = "0.0.0.0"
port = 50051
# Cap of concurrent in-flight RPCs at the server level (L3-API-001).
# gRPC queues excess; tune up for higher-fanout pipelines.
max_concurrent_rpcs = 100
# Rejecting concurrency limit (L3-API-019): 0 disables it (default). Any
# positive value caps concurrently-executing RPCs and rejects excess with
# RESOURCE_EXHAUSTED instead of queuing, giving clients a backpressure signal.
max_in_flight_rpcs = 0

[dashboard]
# FastAPI dashboard listener. Expose only on the management interface.
host = "0.0.0.0"
port = 8080
# When true, the session cookie carries the Secure attribute.
# Production deployments behind TLS termination MUST keep this true;
# dev environments over plaintext HTTP override to false.
https_only = true

# --- Persistence -------------------------------------------------------------

[persistence]
# Absolute path to the SQLite file. Must be on durable local storage
# (not tmpfs, not a network mount -- SQLite and NFS do not agree).
sqlite_path = "/var/lib/message-service/message-service.db"

# v1 uses a single shared aiosqlite connection serialized via an
# asyncio.Lock around BEGIN/COMMIT (L2-PERS-004). There is no
# connection_pool_size key. The pool architecture is preserved as a
# future evolution path in docs/archive/connection-pool-architecture.md
# along with the re-evaluation triggers that would justify revisiting.

[persistence.filesystem]
# Rendered reports are written here before being attached to emails.
# Must be writable by the service user.
report_directory = "/var/lib/message-service/reports"

# Rendered-report retention pruner (L1-PERS-004 / L2-PERS-011/012/013).
#
# report_retention_days
#   Minimum days a rendered report SHALL be retained on disk before the
#   pruner is permitted to evict it (L3-PERS-027). Default 90 covers a
#   typical post-incident investigation window. Operators with stricter
#   retention requirements should raise this value; the pruner will not
#   evict reports younger than the configured threshold regardless of
#   disk pressure.
#
# prune_interval_seconds
#   How often the pruner-loop wakes up to scan for eligible reports
#   (L3-PERS-029). Default 86400 (daily). The pruner uses the same
#   BackgroundTaskScheduler as the orphan sweeper, so this cadence is
#   observed in service-process wall time, not cron-style triggers.
#
# max_prunes_per_iteration
#   Per-tick deletion cap (L3-PERS-029). A large eviction backlog
#   (post-extended-downtime, post-policy-change) drains across multiple
#   ticks rather than monopolizing the SQLite connection in one pass.
#   Mirrors sweeper.max_candidates_per_iteration (L3-SWEEP-008).
report_retention_days = 90
prune_interval_seconds = 86400
max_prunes_per_iteration = 1000

# --- Templates ---------------------------------------------------------------

[templates]
manifest_path = "/etc/message-service/templates.toml"
max_context_bytes = 1_048_576       # 1 MiB -- L3-STAGE-014 limit
max_rendered_bytes = 10_485_760     # 10 MiB -- L3-TMPL-028 limit

# Template used for every run's email body. Must exist in the manifest
# with this (name, version).
[templates.email_body_template_ref]
name = "email_body"
version = "1.0"

# --- Tags + Pipelines --------------------------------------------------------

[tags]
# Controlled-vocabulary file. Runs tagged with anything not in this
# file are rejected at BeginRun.
vocabulary_path = "/etc/message-service/tags.toml"

[pipelines]
# Every pipeline_type a client might send in BeginRun must appear here.
# Unknown types are rejected with UnknownPipelineTypeError (gRPC
# INVALID_ARGUMENT).
registered = [
    "etl-nightly",
    "etl-hourly",
    "backup-daily",
    # Add one line per pipeline your ETL jobs use.
]

# Optional per-pipeline email Subject override (L2-MAIL-014 / R-MAIL-001).
# Maps a registered pipeline_type to a template rendered with Python
# str.format; only the {pipeline_type} and {run_id} placeholders are allowed
# ({pipeline_type} is sanitized before substitution). A pipeline with no entry
# uses the default subject "[{pipeline_type}] run {run_id}", so omitting this
# table entirely preserves the built-in behavior. Keys must be in `registered`.
# [pipelines.subject_templates]
# etl-nightly = "[NIGHTLY:{pipeline_type}] run {run_id}"
# backup-daily = "Backup {pipeline_type} completed (run {run_id})"

# Optional per-pipeline email BODY template override (L2-TMPL-015 / R-TMPL-001).
# Maps a registered pipeline_type to a manifest-registered template (name +
# explicit version). The referenced template must exist in the manifest (checked
# at startup). A pipeline with no entry renders the body from the service-wide
# templates.email_body_template_ref, so omitting this table preserves the
# single-template behavior. Keys must be in `registered`.
# [pipelines.email_body_template_overrides]
# etl-nightly = { name = "nightly_email_body", version = "1.0" }
# backup-daily = { name = "backup_email_body", version = "2.1" }

# Optional per-pipeline ORPHAN DISPOSITION override (L2-SWEEP-011 / R-SWEEP-001).
# Maps a registered pipeline_type to an ordered list of disposition action ids
# applied by the sweeper when a run of that pipeline orphans, overriding the
# global `sweeper.disposition_actions` (below). A pipeline with no entry uses the
# global policy; an empty list [] means "orphan but take no action". Keys must be
# in `registered`, and every action id must have a registered handler (checked at
# startup — same as the global policy; v1 implements DISCARD_SILENTLY and
# NOTIFY_ADMINS only).
# [pipelines.orphan_disposition_overrides]
# etl-nightly = ["NOTIFY_ADMINS", "DISCARD_SILENTLY"]
# ingestion-test = ["DISCARD_SILENTLY"]

# --- Sweeper -----------------------------------------------------------------
# The orphan sweeper periodically transitions runs stuck in active
# states (INITIATED, AGGREGATING, READY, SENDING) to ORPHANED and
# invokes the configured disposition actions in list order.

[sweeper]
# Age threshold (since last transition). Tune per pipeline SLA.
run_timeout_seconds = 3_600          # 1 h

# How often the sweeper checks. A smaller value reduces detection
# latency at the cost of more DB polling.
poll_interval_seconds = 60

# Maximum orphan candidates the sweeper claims per tick. Backlogs
# larger than this drain over multiple ticks at the configured
# poll_interval_seconds cadence; bounding per-tick work keeps the
# shared SQLite connection responsive for gRPC ingest. Default 1000
# matches L3-SWEEP-008's spec.
max_candidates_per_iteration = 1000

# How long a sweeper_actions row may sit claimed-but-not-completed
# before the dispatcher will re-claim it. This recovers rows that
# were claimed by a dispatcher process that crashed mid-handler.
# Default 300s mirrors L3-SWEEP-020's spec; tune higher if your
# typical handler can run longer than this.
stale_claim_threshold_seconds = 300

# Maximum dispatch attempts before a stuck row is abandoned.
# When a row's attempts reaches this cap and it's still stuck,
# the dispatcher emits a DISPATCHER_ACTION_ABANDONED audit event
# and marks the row terminal so it stops being scanned (per
# L3-SWEEP-021). Operators should query the audit log for the
# abandoned action_id to investigate what's persistently failing.
max_dispatch_attempts = 3

# Actions taken per orphaned run, in this order. Currently-supported:
#   "NOTIFY_ADMINS"        -- logs at WARNING level (hooks to your log pipeline)
#   "DISCARD_SILENTLY"     -- no further action; audit event is the record
#   "SEND_PARTIAL_FLAGGED" -- NOT YET IMPLEMENTED -- will raise
#   "NOTIFY_SUBSCRIBERS"   -- NOT YET IMPLEMENTED -- will raise
# See ROADMAP for timing of the two deferred handlers.
disposition_actions = ["NOTIFY_ADMINS", "DISCARD_SILENTLY"]

# --- Mail --------------------------------------------------------------------

[mail]
# Envelope sender. Must be a valid email address.
from_address = "message-service@example.com"

# Reject outbound emails larger than this before handing to SMTP,
# to surface size failures as structured FAILED runs rather than
# SMTP 5xx rejections after the fact.
max_email_size_bytes = 26_214_400    # 25 MiB

# Recipients for NOTIFY_ADMINS (once that handler does real mail;
# currently log-only). List may be empty.
admin_recipients = [
    "ops-team@example.com",
    "oncall-sre@example.com",
]

[mail.smtp]
host = "smtp.example.com"
port = 587

# These TWO fields support ${env:VAR} substitution (SubstitutableStr).
# Put the real values in your secret store; point the vars at them
# via systemd EnvironmentFile, Vault agent, or equivalent.
username = "${env:MESSAGE_SERVICE_SMTP_USERNAME}"
password = "${env:MESSAGE_SERVICE_SMTP_PASSWORD}"

# STARTTLS upgrade from plaintext. Use true unless you have a specific
# reason (internal relay with IP allowlisting, etc.).
use_starttls = true

[mail.retry]
# Exponential-backoff parameters for transient SMTP failures.
# Effective delay = min(max, initial * 2^(n-1)).
max_retries = 5
initial_interval_seconds = 2
max_interval_seconds = 300           # 5 min cap

# --- Auth (dashboard) --------------------------------------------------------
# Used by the FastAPI dashboard; not involved in gRPC ingest.

[auth]
# Session expires after this long of no dashboard activity.
session_idle_timeout_seconds = 3_600 # 1 h

[auth.argon2]
# Argon2id parameters. Defaults are OWASP 2023 recommendations;
# tune upward if your hardware can afford it.
memory_cost = 65_536                 # KiB
time_cost = 3
parallelism = 4

# Optional configurable local administrator account (L1-AUTH-004). When this
# section is present, the service provisions a local admin at startup: it
# creates the account if absent (admin privilege, enabled, password hashed with
# Argon2id) and, if it already exists, re-asserts admin + enabled WITHOUT
# resetting a password rotated through the admin console. Omit the section
# entirely to disable this bootstrap. Keep the secret out of this file by
# substituting it from the environment, exactly like smtp.password.
# [auth.admin]
# email = "admin@example.com"
# password = "${env:MESSAGE_SERVICE_ADMIN_PASSWORD}"

# --- Observability -----------------------------------------------------------

[observability]
# One of: "DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL".
# Use INFO in production; DEBUG is noisy.
log_level = "INFO"

[observability.audit]
# Audit log retention + retention-pruner knobs (L1-OBS-003 / L2-OBS-008 /
# L2-OBS-009).
#
# retention_days
#   How long SUCCESS/FAILURE audit rows are kept before the retention
#   pruner deletes them (L3-OBS-015). Default 365 covers the common
#   1-year compliance horizon; regulated environments often need 7+
#   years. Rows older than (now - retention_days) become eligible.
#
# cleanup_interval_hours
#   Pruner-loop polling cadence (L3-OBS-014). Default 24 (daily). The
#   pruner uses the same BackgroundTaskScheduler as the orphan
#   sweeper and the rendered-report retention pruner, so this cadence
#   is observed in service-process wall time.
#
# cleanup_batch_size
#   Per-tick DELETE row cap (L3-OBS-016). Default 10000 keeps any
#   individual DELETE statement short enough not to monopolize the
#   shared SQLite connection while other writers (gRPC, sweeper,
#   report-pruner) are queued behind the L2-PERS-004 mutex. Operators
#   with very large audit-log backlogs (e.g., a retention-policy
#   tightening that suddenly makes years of rows eligible) can lower
#   this further; the backlog drains across multiple ticks regardless.
#
# archive_directory  (optional, L2-OBS-019 / L3-OBS-041)
#   When set, the retention pruner writes each expired batch to a durable
#   archive under this directory as newline-delimited JSON
#   (audit-archive-<date>.jsonl) BEFORE deleting the rows — so long-term
#   investigative/compliance needs survive retention pruning. The archive is
#   flushed to disk before the delete; if the archive write fails the tick
#   deletes nothing (rows retained, retried next tick), so no record is ever
#   deleted without first being archived. The directory is created and
#   probe-validated at startup. Omit (the default) to delete without archiving.
retention_days = 365
cleanup_interval_hours = 24
cleanup_batch_size = 10000
# archive_directory = "/var/lib/message-service/audit-archive"

# --- Service -----------------------------------------------------------------

[service]
# How long `shutdown_service` will wait for in-flight background tasks
# (sweeper loop, in-flight AssembleAndDeliver deliveries) to finish
# before cancelling them. Tune up if you send large reports; tune
# down for aggressive deploys.
shutdown_grace_period_seconds = 30
